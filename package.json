{
  "name": "poke-card-daily-batch",
  "version": "1.0.0",
  "description": "Pokemon Price Tracker API からデータを取得する Supabase 用バッチ処理",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "batch": "node src/index.js",
    "batch:sets": "node src/index.js --type sets",
    "batch:cards": "node src/index.js --type cards",
    "batch:prices": "node src/index.js --type prices",
    "batch:sealed": "node src/index.js --type sealed",
    "batch:full": "node src/index.js --type full",
    "batch:sets:diff": "node src/index.js --type sets --mode diff",
    "batch:cards:diff": "node src/index.js --type cards --mode diff",
    "batch:prices:diff": "node src/index.js --type prices --mode diff",
    "batch:sealed:diff": "node src/index.js --type sealed --mode diff",
    "batch:diff": "node src/index.js --type diff",
    "db:migrate": "supabase db push"
  },
  "keywords": [
    "pokemon",
    "tcg",
    "batch",
    "supabase"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@supabase/supabase-js": "^2.45.0",
    "dotenv": "^16.4.5",
    "node-fetch": "^3.3.2"
  }
}
