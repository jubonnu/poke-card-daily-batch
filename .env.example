# Pokemon Price Tracker API
# https://pokemonpricetracker.com/api で取得
POKEMON_API_KEY=pokeprice_pro_aa92fc431a5de3744065fa1051f4327ff9e954379aec41ef

# オプション
POKEMON_API_BASE_URL=https://www.pokemonpricetracker.com/api/v2
POKEMON_API_LANGUAGE=japanese
RATE_LIMIT_MS=1100
# API リトライ（429・5xx・ネットワークエラー時）。回数（デフォルト 3）、初回待機 ms（デフォルト 5000、指数バックオフ）
# API_MAX_RETRIES=3
# API_RETRY_DELAY_MS=5000

# Supabase
# https://supabase.com プロジェクト設定から取得
SUPABASE_URL=https://retcyhjckvkbjhhmfelc.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InJldGN5aGpja3ZrYmpoaG1mZWxjIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImlhdCI6MTc1NjQwMTY5OSwiZXhwIjoyMDcxOTc3Njk5fQ.tdA7pxcDXtFmpAd6f_LQTXbgbSo4HcpO3IlGZjv4FYY

# 為替（バッチ保存時の USD→JPY 換算に使用。未設定時は 200）
# USD_JPY_RATE=200

# バッチ設定
BATCH_CARDS_PER_REQUEST=50
# 0=全セット取得（バッチ1回で全データ取得）。正の数で取得セット数制限
BATCH_MAX_SETS=0
BATCH_INCLUDE_HISTORY=true
BATCH_INCLUDE_EBAY=true
BATCH_SEALED_INCLUDE_HISTORY=true
# 日次は 1200（429 回避）。短くするとレート制限で 120s リトライが入り遅くなることがある
BATCH_DELAY_MS=1200
# 差分モードの価格 API（未設定時 diff=30日・200点、full=180日・365点）
# BATCH_PRICES_HISTORY_DAYS_DIFF=30
# BATCH_PRICES_MAX_DATA_POINTS_DIFF=200
# フル同期で長い履歴を取りたいとき
# BATCH_PRICES_HISTORY_DAYS_FULL=180
# BATCH_PRICES_MAX_DATA_POINTS_FULL=365
# 両モードを同じに上書き
# BATCH_PRICES_HISTORY_DAYS=180
# BATCH_PRICES_MAX_DATA_POINTS=365
# 先頭から実行する場合に true（未設定時は前回の続きから再開）
# BATCH_FULL_RUN=true
