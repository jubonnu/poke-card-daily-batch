# Pokemon Price Tracker API
# https://pokemonpricetracker.com/api で取得
POKEMON_API_KEY=your_api_key_here

# オプション
POKEMON_API_BASE_URL=https://www.pokemonpricetracker.com/api/v2
POKEMON_API_LANGUAGE=japanese
RATE_LIMIT_MS=1100
# API リトライ（429・5xx・ネットワークエラー時）。回数（デフォルト 3）、初回待機 ms（デフォルト 5000、指数バックオフ）
# API_MAX_RETRIES=3
# API_RETRY_DELAY_MS=5000

# Supabase
# https://supabase.com プロジェクト設定から取得
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# 為替（バッチ保存時の USD→JPY 換算に使用。未設定時は 150）
# USD_JPY_RATE=150

# バッチ設定
BATCH_CARDS_PER_REQUEST=50
# 0=全セット取得（バッチ1回で全データ取得）。正の数で取得セット数制限
BATCH_MAX_SETS=0
BATCH_INCLUDE_HISTORY=true
BATCH_INCLUDE_EBAY=true
BATCH_SEALED_INCLUDE_HISTORY=true
BATCH_DELAY_MS=2000
# 先頭から実行する場合に true（未設定時は前回の続きから再開）
# BATCH_FULL_RUN=true
